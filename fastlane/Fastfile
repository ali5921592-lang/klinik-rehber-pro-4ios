default_platform(:ios)

platform :ios do
  desc "iOS uygulamasini arsivler ve App Store'a hazir .ipa olarak disa aktarir"
  lane :build_release do
    team_id = ENV["IOS_TEAM_ID"]
    profile_name = ENV["IOS_PROFILE_NAME"]
    bundle_id = ENV["BUNDLE_ID"]

    UI.user_error!("IOS_TEAM_ID ortam degiskeni eksik") if team_id.nil? || team_id.empty?
    UI.user_error!("IOS_PROFILE_NAME ortam degiskeni eksik") if profile_name.nil? || profile_name.empty?
    UI.user_error!("BUNDLE_ID ortam degiskeni eksik") if bundle_id.nil? || bundle_id.empty?

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ipa",
      output_name: "App.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          bundle_id => profile_name
        },
        signingStyle: "manual",
        teamID: team_id
      },
      xcargs: "CODE_SIGN_STYLE=Manual \"CODE_SIGN_IDENTITY=Apple Distribution\" \"PROVISIONING_PROFILE_SPECIFIER=#{profile_name}\" DEVELOPMENT_TEAM=#{team_id}"
    )
  end
end
